# ─── Token Launch Screener MCP ────────────────────────────────────────────────
#
# Required: Get a free key at https://etherscan.io/apikey
# Note: Free tier covers Ethereum mainnet. Other chains require an upgraded plan.
#
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Optional: HTTP port (default: 3000)
PORT=3000

# Optional: Transport mode — "http" for remote deployment, "stdio" for local
TRANSPORT=http
