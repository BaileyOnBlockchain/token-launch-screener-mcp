# ─── Token Launch Screener MCP ────────────────────────────────────────────────
#
# One Etherscan V2 key covers all 60+ EVM chains (Base, BSC, Polygon, Arbitrum,
# Optimism, Avalanche, and more). Get a free key at https://etherscan.io/myapikey
#
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ─── Server ────────────────────────────────────────────────────────────────────

# Optional: HTTP port (default: 3000)
PORT=3000

# Optional: Transport mode — "http" for remote deployment, "stdio" for local
TRANSPORT=http
